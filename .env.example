# q1729 environment — copy to .env (gitignored) or export in your shell.
# Only the NIM narrator (analysis/narrator.py, ADR 003) needs any of this;
# everything else in the repo runs without secrets.

# NVIDIA NIM API key — create one at https://build.nvidia.com (nvapi-...)
NVIDIA_API_KEY=nvapi-your-key-here

# Optional overrides (defaults shown). NIM retires model ids over time and the
# /v1/models catalog lists entries that 404 on invoke (llama-3.1-nemotron-70b
# did exactly that, 2026-07-10) — verify a new model with `make narrate` first.
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM_MODEL=nvidia/nemotron-3-super-120b-a12b
